<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="Board">
  <select id="getStartEnd" resultType="com.study.app.board.BoardDTO">
        select * from (
    select a.*, rownum rnum from (
        select * from posts order by seq desc
    ) a where #{end} >= rownum
) where rnum >= #{start}
  </select>

  <select id="countPosts" resultType="int">
        select count(*) from posts
  </select>

  <insert id ="postWrite">
        insert into posts values(posts_seq.nextval,#{writer},#{title},#{contents},0,sysdate)
  </insert>

  <select id="getDetail" resultType="com.study.app.board.BoardDTO">
        select * from posts where seq=#{seq}
  </select>

  <update id="detailUpdate">
        update posts set title=#{title}, contents=#{contents} where seq=#{seq}
  </update>

  <delete id="deleteDetail">
        delete from posts where seq=#{seq}
  </delete>
</mapper>
