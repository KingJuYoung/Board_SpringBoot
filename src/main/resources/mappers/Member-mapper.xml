<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="Member">
  <select id="checkId" resultType="int">
        select count(*) from memebers where id=#{id}
  </select>

  <insert id="createNewId">
        insert into memebers values(#{id},#{pw},#{name},#{pw},#{email},#{zonecode},#{address1},#{address2},sysdate)
  </insert>

  <select id="loginId" resultType="int">
        select count(*) from memebers where id=#{id} and pw=#{pw}
  </select>

  <delete id="memberOut">
        delete from memebers where id=#{id}
  </delete>

  <select id="selectAll" resultType="com.study.app.member.MemberDTO">
        select * from memebers where id=#{id}
  </select>

  <update id="updateMyInfo">
        update memebers set name=#{name}, phone=#{phone},email=#{email}, zonecode=#{zonecode}, address1=#{address1}, address2=#{address2} where id=#{id}
  </update>
</mapper>
